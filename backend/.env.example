# =============================================
# Library Management System — Backend Config
# Copy this file to .env and fill in the values
# =============================================

# MongoDB Atlas Connection String
# Get this from: https://cloud.mongodb.com → Connect → Drivers → Node.js
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT Secret Key — must be a long random string in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string-before-deploying

# Server Port
PORT=5000

# Developer Admin & License System Config
# Change these before deployment!
LICENSE_MASTER_SECRET=change-this-license-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# CORS — comma-separated allowed frontend origins (leave blank for localhost dev defaults)
# Example: CORS_ORIGIN=https://app.yourdomain.com,https://kiosk.yourdomain.com
CORS_ORIGIN=
